---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactFooter from '../../components/ContactFooter.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import CTASection from '../../components/CTASection.astro';
import { getPostBySlug, getBlogSlugs } from '../../data/blog';

export async function getStaticPaths() {
  return getBlogSlugs().map((slug) => ({
    params: { slug },
    props: { post: getPostBySlug(slug)! },
  }));
}

const { post } = Astro.props;
---

<Layout title={`${post.title} | UMEIB`}>
  <Navbar />

  <main id="main-content" class="pt-16">
    <article class="py-12 sm:py-16 lg:py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 text-sm text-text-heading/50 mb-6">
          <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          <span class="text-text-heading/85">{post.category}</span>
        </div>

        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-text-heading leading-tight tracking-tight">
          {post.title}
        </h1>

        <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-text-heading/50">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {post.author}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {post.date}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {post.readTime}
          </span>
        </div>

        <div class="mt-8 aspect-[2/1] bg-surface-alt rounded-2xl flex items-center justify-center overflow-hidden">
          <svg class="w-24 h-24 text-primary/20" viewBox="0 0 48 48" fill="none">
            <rect x="6" y="8" width="36" height="32" rx="4" stroke="currentColor" stroke-width="2.5"/>
            <path d="M16 20h16M16 26h12M16 32h8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>

        <div class="mt-10 prose prose-lg max-w-none text-text-heading/80 [&_h2]:text-text-heading [&_h2]:font-bold [&_h2]:text-xl [&_h2]:sm:text-2xl [&_h2]:mt-10 [&_h2]:mb-4 [&_p]:leading-relaxed [&_p]:mb-5 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:leading-relaxed [&_strong]:text-text-heading [&_strong]:font-semibold" set:html={post.content} />

        <div class="mt-12 pt-8 border-t border-gray-100">
          <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-primary-dark font-semibold transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Volver al Blog
          </a>
        </div>
      </div>
    </article>

    <CTASection />
  </main>

  <ContactFooter />
  <WhatsAppButton />
</Layout>

---
import '../styles/global.css';

const { title = 'UMEIB – Unidad Médica de Atención Inmediata' } = Astro.props;
const description = Astro.props.description || 'Soluciones en salud más cerca de ti. Atención médica inmediata en Barquisimeto. Laboratorio, odontología, medicina general y más.';
const image = '/images/og-image.jpg';
const url = 'https://umeib.com';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#12A0A5" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={url} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      name: "UMEIB – Unidad Médica de Atención Inmediata",
      description,
      url,
      telephone: "+58 424-5212582",
      email: "contacto@umeib.com",
      image: "https://umeib.com/images/logo/logo.svg",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Carrera 16 entre calle 27 y 28",
        addressLocality: "Barquisimeto",
        addressCountry: "VE"
      },
      openingHoursSpecification: [
        { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "08:00", closes: "18:00" },
        { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "08:00", closes: "12:00" }
      ],
      medicalSpecialty: [
        "Anesthesiology", "Cardiology", "Dentistry", "Dermatology",
        "Emergency", "Endocrinology", "Gastroenterology",
        "Gynecology", "InternalMedicine", "Neurology",
        "Obstetrics", "Ophthalmology", "Orthopedic",
        "Otolaryngology", "Pediatrics", "PhysicalTherapy",
        "PlasticSurgery", "Psychiatry", "Pulmonary",
        "Radiology", "Surgery", "Urology"
      ]
    })} />
    <title>{title}</title>
  </head>
    <body class="font-sans text-text-heading/85 bg-white antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold">
      Saltar al contenido principal
    </a>
    <slot />
  </body>
</html>

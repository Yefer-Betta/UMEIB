---
import { globalContact } from '../libs/utils';
---
<footer id="contacto" class="bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 lg:gap-12">

      <div>
        <div class="mb-6">
          <img src="/images/logo/logo-stacked.svg" alt="UMEIB" class="w-28" width="120" height="120" />
        </div>
        <p class="text-text-heading/75 text-sm leading-relaxed mb-3">
          Soluciones en salud más cerca de ti. Atención médica inmediata y especializada en Barquisimeto.
        </p>
        <p class="text-xs text-text-heading/60 italic">
          "Soluciones en salud más cerca de ti"
        </p>
      </div>

      <div>
        <h3 class="text-sm font-bold text-text-heading uppercase tracking-wider mb-4">Ubicación</h3>
        <div class="flex items-start gap-3 mb-4">
          <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <p class="text-sm text-text-heading/85 leading-relaxed">
            Carrera 16 entre calle 27 y 28<br />
            Barquisimeto, Venezuela
          </p>
        </div>

        <div class="w-full h-44 rounded-xl overflow-hidden border border-gray-100 shadow-sm">
          <iframe
            src="https://www.openstreetmap.org/export/embed.html?bbox=-69.3483%2C10.0636%2C-69.3383%2C10.0736&amp;layer=mapnik&amp;marker=10.0686%2C-69.3433"
            width="100%"
            height="100%"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de UMEIB en Barquisimeto"
          ></iframe>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-bold text-text-heading uppercase tracking-wider mb-4">Contacto</h3>

        <a href={`https://${globalContact.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 mb-4 group">
          <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="text-sm group-hover:text-primary transition-colors">+58 424-5212582</span>
        </a>

        <a href={`mailto:${globalContact.email}`} class="flex items-center gap-3 mb-6">
          <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span class="text-sm text-text-heading/85">contacto@umeib.com</span>
        </div>

        <h4 class="text-xs font-bold text-text-heading uppercase tracking-wider mb-3">Síguenos</h4>
        <div class="flex items-center gap-3">
          <a href="https://www.instagram.com/umeib2025.ca/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-alt hover:bg-primary flex items-center justify-center text-text-heading/50 hover:text-white transition-all duration-300" aria-label="Instagram">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://www.facebook.com/umeib.ve" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-alt hover:bg-primary flex items-center justify-center text-text-heading/50 hover:text-white transition-all duration-300" aria-label="Facebook">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@umeib.ve" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-alt hover:bg-primary flex items-center justify-center text-text-heading/50 hover:text-white transition-all duration-300" aria-label="TikTok">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 100 8 4 4 0 000-8z"/><path d="M15 8a5 5 0 00-5-5"/><path d="M15 8v8a5 5 0 01-10 0V8"/><path d="M15 8c2 0 4-2 5-3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-100 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-text-heading/60">
        &copy; 2026 UMEIB — Soluciones en salud más cerca de ti
      </p>
      <p class="text-xs text-text-heading/50">
        Carrera 16 entre calle 27 y 28 · Barquisimeto
      </p>
    </div>
  </div>
</footer>

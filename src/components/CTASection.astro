---
import type { Specialty } from '../data/specialties';

interface Props {
  specialty?: Specialty;
  title?: string;
  subtitle?: string;
}

const {
  specialty,
  title = 'Agenda tu consulta hoy',
  subtitle = 'Déjanos tu mensaje y te contactaremos en minutos para agendar tu cita.',
} = Astro.props;
---

<section class="bg-gradient-to-r from-[#102A43] to-[#12A0A5] py-14 sm:py-18">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white tracking-tight">
      {specialty ? `${title} de ${specialty.name}` : title}
    </h2>
    <p class="mt-3 text-base sm:text-lg text-white/80 max-w-xl mx-auto">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
      <a href="https://wa.me/584245212582" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-[#102A43] hover:bg-white/90 font-bold px-8 py-3.5 rounded-full transition-all duration-300 shadow-lg hover:-translate-y-0.5 text-base">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
        {specialty ? `Agendar ${specialty.name}` : 'Agendar Consulta'}
      </a>
      <a href="tel:+584245212582" class="inline-flex items-center gap-2 border-2 border-white/30 hover:border-white/50 text-white/90 hover:text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 text-base">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Llamar Ahora
      </a>
    </div>
  </div>
</section>

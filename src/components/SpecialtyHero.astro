---
import Breadcrumbs from './Breadcrumbs.astro';
import type { Specialty } from '../data/specialties';
import { getDoctorsBySpecialty } from '../data/doctors';

interface Props {
  specialty: Specialty;
}

const { specialty } = Astro.props;
---

<section class="relative min-h-[60vh] flex items-center overflow-hidden bg-gradient-to-br from-[#102A43] via-[#102A43] to-[#12A0A5]">
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px), radial-gradient(circle at 75% 75%, white 1px, transparent 1px); background-size: 60px 60px, 40px 40px;">
  </div>

  <div class="absolute top-0 right-0 w-80 h-80 bg-primary/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"></div>

  <!-- Doctor photo - large, responsive, with soft fade -->
  {
    getDoctorsBySpecialty(specialty.slug).length > 0 && (
      <div class="hidden md:block absolute inset-0 overflow-hidden pointer-events-none">
        <!-- Gradient overlay to ensure text readability -->
        <div class="absolute inset-0 bg-gradient-to-r from-[#102A43]/30 via-[#102A43]/10 to-transparent z-[1]"></div>

        {getDoctorsBySpecialty(specialty.slug).slice(0, 2).map((doctor, i) => (
          <div
            class="absolute -right-10 top-[58%] -translate-y-1/2 w-[60vw] h-[60vw] max-w-[800px] max-h-[800px] animate-fade-in"
            style={`mask-image: radial-gradient(ellipse at 50% 50%, black 45%, transparent 78%); -webkit-mask-image: radial-gradient(ellipse at 50% 50%, black 45%, transparent 78%); ${i > 0 ? 'margin-top: 4rem; margin-right: -5rem;' : ''}`}
          >
            <img
              src={doctor.photo}
              alt=""
              class="w-full h-full object-contain drop-shadow-2xl"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    )
  }

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-28 w-full">
    <Breadcrumbs crumbs={[
      { label: 'Especialidades', href: '/#especialidades' },
      { label: specialty.name },
    ]} />

    <div class="max-w-3xl">
      <div class="w-14 h-14 sm:w-16 sm:h-16 text-primary mb-5 [&_svg]:w-full [&_svg]:h-full animate-fade-in" set:html={specialty.icon}>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight animate-fade-in-up">
        {specialty.heroTitle}
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl text-primary font-semibold mt-3 animate-fade-in-up delay-100">
        {specialty.heroSubtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-8 animate-fade-in-up delay-200">
        <a href="https://wa.me/584245212582" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold px-7 py-3.5 rounded-full transition-all duration-300 shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-0.5 text-base">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Agendar Consulta
        </a>
        <a href="https://wa.me/584245212582" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 border-2 border-white/20 hover:border-white/40 text-white/80 hover:text-white font-semibold px-7 py-3.5 rounded-full transition-all duration-300 text-base">
          Consultar Disponibilidad
        </a>
      </div>
    </div>
  </div>
</section>

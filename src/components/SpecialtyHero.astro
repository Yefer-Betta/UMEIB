---
import Breadcrumbs from './Breadcrumbs.astro';
import type { Specialty } from '../data/specialties';
import { getDoctorsBySpecialty } from '../data/doctors';

interface Props {
  specialty: Specialty;
}

const { specialty } = Astro.props;
const doctors = getDoctorsBySpecialty(specialty.slug);

function getInitials(name: string): string {
  return name
    .replace(/^(Dr\.|Dra\.|Lic\.)\s+/i, '')
    .split(' ')
    .filter(w => w.length > 0)
    .map(w => w[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
}
---

<section class="relative overflow-hidden bg-gradient-to-b from-[#EEF7F8] via-white to-white">
  <!-- Decorative organic background shapes -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] opacity-20 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 600 600" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="380" cy="150" r="280" fill="#12A0A5"/>
      <circle cx="200" cy="380" r="180" fill="#C8E6C9" opacity="0.4"/>
    </svg>
  </div>
  <div class="absolute -bottom-24 -left-24 w-[450px] h-[450px] opacity-15 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 450 450" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="80" cy="370" r="230" fill="#81D4D9"/>
    </svg>
  </div>

  <!-- Subtle medical dots pattern -->
  <div class="absolute inset-0 opacity-[0.025] pointer-events-none" style="background-image: radial-gradient(circle at 30% 40%, #102A43 1px, transparent 1px); background-size: 56px 56px;" aria-hidden="true"></div>

  <div class="relative min-h-[70vh] flex items-center">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24 lg:py-28">
      <Breadcrumbs crumbs={[
        { label: 'Especialidades', href: '/#especialidades' },
        { label: specialty.name },
      ]} />

      <div class="flex flex-col lg:flex-row lg:items-center gap-10 lg:gap-16 mt-4">
        <!-- Left: Content column -->
        <div class="flex-1 max-w-xl">
          <div class="w-14 h-14 sm:w-16 sm:h-16 text-primary mb-5 [&_svg]:w-full [&_svg]:h-full animate-fade-in" set:html={specialty.icon}>
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-text-heading leading-tight tracking-tight animate-fade-in-up">
            {specialty.heroTitle}
          </h1>

          <p class="text-lg sm:text-xl md:text-2xl text-text-heading/70 font-medium mt-3 animate-fade-in-up delay-100">
            {specialty.heroSubtitle}
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mt-8 animate-fade-in-up delay-200">
            <a href="https://wa.me/584245212582" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold px-7 py-3.5 rounded-full transition-all duration-300 shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-0.5 text-base">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Agendar Consulta
            </a>
              <a href="https://wa.me/584245212582" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 border-2 border-primary/40 hover:border-primary text-text-heading/70 hover:text-primary font-semibold px-7 py-3.5 rounded-full transition-all duration-300 text-base">
              Consultar Disponibilidad
            </a>
          </div>
        </div>

        <!-- Right: Doctor info cards -->
        {
          doctors.length > 0 && (
            <div class="flex-1 flex justify-center lg:justify-end items-center">
              <div class="flex flex-col gap-5 w-full max-w-sm">
                {doctors.map((doctor) => (
                  <div class="group bg-white/85 backdrop-blur-md rounded-2xl p-5 sm:p-6 border border-white/60 shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
                    <div class="flex items-start gap-4">
                      <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center text-white text-lg sm:text-xl font-bold shrink-0 shadow-lg shadow-primary/20">
                        {getInitials(doctor.name)}
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-base sm:text-lg font-bold text-text-heading leading-tight">{doctor.name}</p>
                        <span class="inline-block mt-1 text-xs font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">{specialty.name}</span>
                        {
                          doctor.contact.phone && (
                            <div class="mt-3 flex items-center gap-2 text-text-heading/75">
                              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                              <a href={`tel:${doctor.contact.phone}`} class="text-sm text-text-heading/75 hover:text-primary transition-colors">{doctor.contact.phone}</a>
                            </div>
                          )
                        }
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>

  <!-- Curved bottom transition to next section -->
  <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[50px] sm:h-[60px] lg:h-[80px]">
      <path fill="white" d="M0,0 Q360,60 720,30 T1440,0 V60 H0 Z"/>
    </svg>
  </div>
</section>

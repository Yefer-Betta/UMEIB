---
import BlogCard from './BlogCard.astro';
import type { BlogPost } from '../data/blog';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
  {posts.map((post) => <BlogCard post={post} />)}
</div>
